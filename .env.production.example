# MongoDB Atlas Production Environment Configuration
# Copy this file to .env and fill in your MongoDB Atlas details

# ==================== GROQ LLM CONFIGURATION ====================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ==================== SERVER CONFIGURATION ====================
API_PORT=8000
DEBUG=False
ENVIRONMENT=production

# ==================== LLM CONFIGURATION ====================
LLM_TIMEOUT=30
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.3

# ==================== CORS CONFIGURATION ====================
# For production, replace with your actual frontend domain
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ==================== MULTILINGUAL CONFIGURATION ====================
ENABLE_MULTILINGUAL=True
DEFAULT_LANGUAGE=en

# ==================== MONGODB ATLAS CONFIGURATION ====================
# Replace with your MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Get this from MongoDB Atlas:
# 1. Go to Database → Connect
# 2. Choose Drivers (Python)
# 3. Copy the connection string
# 4. Replace username, password, and cluster info

MONGODB_URL=mongodb+srv://smart_legal_user:YourPasswordHere@smart-legal-db.abc123xyz.mongodb.net/smart_legal_db?retryWrites=true&w=majority
MONGODB_DB_NAME=smart_legal_db

# ==================== SECURITY CONFIGURATION ====================
SECRET_KEY=your-super-secret-key-change-this-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== FEATURE FLAGS ====================
ENABLE_AUDIT_LOGGING=True
ENABLE_FEEDBACK=True
ENABLE_PREDICTIONS=True

# ==================== PRODUCTION NOTES ====================
# 1. NEVER commit this file to version control
# 2. Keep a secure copy of this .env file
# 3. Rotate SECRET_KEY regularly
# 4. Use environment variables instead of .env in production servers
# 5. Enable two-factor authentication in MongoDB Atlas
# 6. Set up IP whitelist in MongoDB Atlas Network Access
# 7. Monitor MongoDB Atlas for unusual activity
# 8. Set up automated backups in MongoDB Atlas
