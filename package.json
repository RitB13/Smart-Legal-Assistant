{
  "name": "smart-legal-assistant",
  "version": "1.0.0",
  "description": "AI-powered legal assistant with case outcome prediction and legal guidance",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "dev:backend": "uvicorn app:app --reload",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev\"",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
